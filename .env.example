# Vault — the only real secret needed locally (dev mode root token)
VAULT_ROOT_TOKEN=root

# Postgres bootstrap password; must match the teammate-owned Vault postgres_password
POSTGRES_PASSWORD=postgres

# Ports — override if a port is already in use on your machine
API_PORT=8000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
SFTP_PORT=2222
VAULT_PORT=8200

